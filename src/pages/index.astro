---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* تنسيقات فاخرة وعصرية مخصصة للهاتف ومريحة للعين */
			body {
				background-color: #0f172a;
				color: #f8fafc;
				font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
			}
			.hero-section {
				text-align: center;
				padding: 60px 20px;
				background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
				border-bottom: 1px solid #334155;
			}
			.hero-title {
				font-size: 2.5rem;
				font-weight: 800;
				background: linear-gradient(to right, #38bdf8, #818cf8);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 15px;
			}
			.hero-subtitle {
				font-size: 1.1rem;
				color: #94a3b8;
				max-width: 600px;
				margin: 0 auto 30px auto;
				line-height: 1.6;
			}
			.cta-button {
				display: inline-block;
				background-color: #3b82f6;
				color: #ffffff;
				padding: 12px 28px;
				border-radius: 50px;
				font-weight: 600;
				text-decoration: none;
				transition: all 0.3s ease;
				box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
			}
			.features-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 20px;
				padding: 40px 20px;
				max-width: 1200px;
				margin: 0 auto;
			}
			.feature-card {
				background-color: #1e293b;
				padding: 25px;
				border-radius: 16px;
				border: 1px solid #334155;
				transition: transform 0.2s ease;
			}
			.feature-card h3 {
				font-size: 1.3rem;
				color: #38bdf8;
				margin-bottom: 10px;
			}
			.feature-card p {
				color: #94a3b8;
				font-size: 0.95rem;
				line-height: 1.5;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- القسم الرئيسي الفاخر المخصص لك -->
			<section class="hero-section">
				<h1 class="hero-title">موقع Ziyed الرسمي</h1>
				<p class="hero-subtitle">
					مرحباً بكم في المنصة الرقمية الخاصة بي. هنا نشارككم أحدث المشاريع والأفكار والرؤى في مجالات التجارة والابتكار الرقمي.
				</p>
				<a href="#projects" class="cta-button">اكتشف مشاريعنا</a>
			</section>

			<!-- قسم استعراض الخدمات والأعمال -->
			<section class="features-grid" id="projects">
				<div class="feature-card">
					<h3>التجارة الإلكترونية</h3>
					<p>تطوير إستراتيجيات وحلول ذكية تضمن إدارة وتوسيع نطاق المشاريع التجارية بكفاءة عالية في السوق الحديث.</p>
				</div>
				<div class="feature-card">
					<h3>تطوير الأفكار والـ SaaS</h3>
					<p>تحويل الرؤى والأفكار المبتكرة إلى تطبيقات عملية وخدمات برمجية سحابية تسهل أتمتة الأعمال رقمياً.</p>
				</div>
				<div class="feature-card">
					<h3>صناعة المحتوى الرقمي</h3>
					<p>بناء حضور رقمي قوي من خلال إستراتيجيات تسويقية عصرية ومحتوى هادف يواكب التطلعات الحالية للجمهور.</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
